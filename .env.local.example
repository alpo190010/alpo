# --- OpenRouter (optional AI features -- env var named OPENAI_API_KEY but hits openrouter.ai, dormant at launch) ---
OPENAI_API_KEY=sk-...

# --- Google PageSpeed Insights (live performance scores during scans) ---
# Without this, every scan falls back to HTML-only signals and the UI shows
# "Google PageSpeed Insights didn't respond". Free tier: 25k queries/day.
# Get a key: https://console.cloud.google.com/apis/credentials (enable
# "PageSpeed Insights API" first under APIs & Services > Library).
GOOGLE_PAGESPEED_API_KEY=AIza...

# --- Paddle (billing — checkout via Paddle.js + webhooks) ---
# Public (exposed to the webapp at build time) — used by /pricing to open the
# inline Paddle.Checkout overlay.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_or_test_client_token
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_PRICE_STARTER_MONTHLY=pri_monthly_xxx
NEXT_PUBLIC_PADDLE_PRICE_STARTER_ANNUAL=pri_annual_xxx

# Server-only — used by the FastAPI /webhook route and any server-side Paddle API calls
PADDLE_API_KEY=sk_or_pk_live_or_test_key
PADDLE_WEBHOOK_SECRET=whsec_...
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_STARTER_MONTHLY=pri_monthly_xxx
PADDLE_PRICE_STARTER_ANNUAL=pri_annual_xxx

# --- Resend (email delivery -- dormant at launch) ---
RESEND_API_KEY=re_...

# --- API URL -- points the webapp at the FastAPI backend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Base URL -- public-facing base URL for the webapp ---
NEXT_PUBLIC_BASE_URL=http://localhost:3005

# --- CORS -- allowed origins for the FastAPI backend ---
CORS_ORIGINS=http://localhost:3005
